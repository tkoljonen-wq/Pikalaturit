# Kopioi tämä tiedostoksi .env ja täytä arvot Supabase-projektista.
# .env on .gitignoressa — älä committaa salaisuuksia.

# Postgres-yhteysmerkkijono migraatioiden ajoon (scripts/migrate.mjs).
# Supabase Dashboard → Project Settings → Database → Connection string → URI.
# Käytä "Session"/direct-yhteyttä (port 5432) tai "Transaction"-poolaria (port 6543).
# Korvaa [YOUR-PASSWORD] tietokannan salasanalla.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Collectorin Supabase-yhteys (service_role ohittaa RLS:n — pidä salassa).
# Dashboard → Project Settings → API.
SUPABASE_URL=https://cwnrqwoijplfnspxzilq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# Valinnainen: polku Supabasen CA-varmenteeseen, jos TLS-varmennus epäonnistuu.
# SUPABASE_CA_CERT=./supabase/prod-ca-2021.crt
