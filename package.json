{
  "name": "afir-pikalaturit-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AFIR-pikalaturiseuranta: domain-malli, parseri ja aggregointi (vaihe 2, UI-riippumaton)",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "collector": "tsx collector/run.ts",
    "db:migrate": "node --env-file-if-exists=.env scripts/migrate.mjs",
    "collect:metadata": "node --env-file-if-exists=.env --import tsx collector/run.ts metadata",
    "collect:status": "node --env-file-if-exists=.env --import tsx collector/run.ts status",
    "create-user": "node --env-file-if-exists=.env scripts/create-user.mjs",
    "setup-metadata-cron": "node --env-file-if-exists=.env scripts/setup-metadata-cron.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "pg": "^8.21.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2"
  }
}
